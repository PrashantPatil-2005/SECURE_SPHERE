# ──────────────────────────────────────────────────────────────────────────────
# SecuriSphere — Environment Variables
# Copy this file to .env and adjust values for your environment.
# Production: every CHANGE_ME must be replaced with a strong unique value.
# ──────────────────────────────────────────────────────────────────────────────

# --- PostgreSQL ---
# Option 1 (recommended for managed DB / cloud): single connection string
# DATABASE_URL=postgresql://user:password@hostname.neon.tech/dbname?sslmode=require
#
# Option 2: individual variables (default for local Docker Compose)
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_USER=securisphere_user
POSTGRES_DB=securisphere_db
POSTGRES_HOST=database
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
# Optional Redis password for production (leave blank for local docker)
REDIS_PASSWORD=

# --- JWT (REQUIRED — backend will refuse to boot if missing in prod) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_min_32_byte_random_string
JWT_EXPIRATION_HOURS=1

# --- CORS ---
# Comma-separated allowed origins. Use exact origins in production.
# Wildcard "*" only acceptable for local development.
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# --- Rate limiting (per-IP defaults) ---
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_ATTACK=5/hour

# --- Discord Notifications ---
DISCORD_WEBHOOK_URL=

# --- Topology Collector ---
TOPOLOGY_REFRESH_INTERVAL=10

# --- Docker Compose ---
COMPOSE_PROJECT_NAME=securisphere

# --- Correlation Engine ---
CORRELATION_WINDOW=900
RISK_DECAY_RATE=5
RISK_DECAY_INTERVAL=60

# --- React Frontend ---
REACT_APP_BACKEND_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# --- Hugging Face AI (Kill Chain Narration) ---
# Get a free token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=
HF_MODEL=Qwen/Qwen2.5-72B-Instruct

# --- Hardening flags ---
FLASK_ENV=production
ALLOW_LOCALHOST_UPSTREAM=0

# --- Web server ---
GUNICORN_WORKERS=1
GUNICORN_WORKER_CLASS=geventwebsocket.gunicorn.workers.GeventWebSocketWorker
GUNICORN_TIMEOUT=120
