# ──────────────────────────────────────────────────────────────────────────────
# SecuriSphere — Environment Variables
# Copy this file to .env and adjust values for your environment.
# ──────────────────────────────────────────────────────────────────────────────

# --- PostgreSQL ---
POSTGRES_PASSWORD=securisphere_pass_2024   # Database password
POSTGRES_USER=securisphere_user            # Database user
POSTGRES_DB=securisphere_db                # Database name
POSTGRES_HOST=database                     # Hostname of the PostgreSQL container
POSTGRES_PORT=5432                         # PostgreSQL port

# --- Redis ---
REDIS_HOST=redis                           # Hostname of the Redis container
REDIS_PORT=6379                            # Redis port

# --- Discord Notifications ---
DISCORD_WEBHOOK_URL=                       # Discord webhook URL for security alerts (leave blank to disable)

# --- Topology Collector ---
TOPOLOGY_REFRESH_INTERVAL=10               # Seconds between Docker topology scans

# --- Docker Compose ---
COMPOSE_PROJECT_NAME=securisphere          # Docker Compose project name (prefixes container names)

# --- Correlation Engine ---
CORRELATION_WINDOW=900                     # Sliding window in seconds for event correlation (default 15 min)
RISK_DECAY_RATE=5                          # Points subtracted from risk scores each decay interval

# --- React Frontend ---
REACT_APP_BACKEND_URL=http://localhost:8000  # Backend API URL used by the React dashboard

# --- Hugging Face AI (Kill Chain Narration) ---
# Free Hugging Face Inference API token for AI kill chain narration
# Get your free token at: https://huggingface.co/settings/tokens
# No credit card required. Paste your token below.
HF_API_TOKEN=
HF_MODEL=Qwen/Qwen2.5-72B-Instruct
