# --- VCS / IDE ---
.git
.gitignore
.github
.vscode
.idea
*.swp
.DS_Store
Thumbs.db

# --- Secrets / env ---
.env
.env.*
!.env.example

# --- Python ---
__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info
.venv
venv
.pytest_cache
.coverage
htmlcov
.tox
